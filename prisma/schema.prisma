// Prisma schema for USM Evently
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum RegistrationStatus {
  REGISTERED
  CANCELLED
  ATTENDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum IdentityType {
  MATRIC
  IC
  PASSPORT
}

enum OrganizerStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  avatarUrl    String?
  myCSDPoints  Int      @default(0)
  role         Role     @default(STUDENT)

  // Identity verification: every account must be a traceable USM student or
  // staff member (matric no. / IC / passport) so bad actors can be identified.
  identityType   IdentityType?
  identityNumber String?

  // Organizer self-service: students may request organizer rights, which an
  // admin approves before they can submit events for review.
  organizerStatus OrganizerStatus @default(NONE)
  organization    String? // club / society / department they represent
  organizerNote   String? // why they want to organize (request message)

  blocked       Boolean  @default(false)
  blockedReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations   Registration[]
  payments        Payment[]
  submittedEvents Event[]        @relation("SubmittedEvents")
}

/// Emails an admin has banned from the platform. Checked at both
/// registration and login so a blocked account (or address) cannot return.
model BlockedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  startTime   String?
  endTime     String?
  location    String
  campus      String // Main / Engineering / Health campus of USM
  school      String? // Organising school or faculty
  organizer   String? // Organising club, society, or department

  // Visitor policy & safety
  openToPublic     Boolean @default(false) // are outsiders (non-USM) allowed?
  dressCode        String? // required attire, if any
  culturalNotes    String? // etiquette / cultural rules visitors must observe
  emergencyContact String // organizer emergency helpline (required)

  imageUrl  String?
  posterUrl String? // uploaded event poster (JPG/PNG, stored as a data URL)
  category  String?
  capacity  Int?
  price     Float   @default(0)
  csdPoints Int     @default(0)

  // Optional alternative payment: organizers who don't want to use the
  // built-in platform checkout can provide their own details instead.
  useExternalPayment  Boolean @default(false)
  bankName            String?
  bankAccountName     String?
  bankAccountNumber   String?
  tngNumber           String? // Touch 'n Go eWallet number / ID
  paymentQrUrl        String? // payment QR image (JPG/PNG, stored as a data URL)
  paymentInstructions String?

  // Moderation: events submitted by organizers await admin approval before
  // they appear publicly. Admin-created events default to APPROVED.
  status          EventStatus @default(APPROVED)
  rejectionReason String?
  submittedById   String?
  submittedBy     User?       @relation("SubmittedEvents", fields: [submittedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations Registration[]
  payments      Payment[]
}

model Registration {
  id         String             @id @default(cuid())
  status     RegistrationStatus @default(REGISTERED)
  attendedAt DateTime? // set when an organizer/admin checks the ticket in
  createdAt  DateTime           @default(now())

  userId  String
  eventId String
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Payment {
  id          String        @id @default(cuid())
  amount      Float
  description String?
  status      PaymentStatus @default(COMPLETED)
  createdAt   DateTime      @default(now())

  userId  String
  eventId String?
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}
